  },
  "bugs": {
    "url": "https://github.com/ArikaJs/arikajs/issues"
  },
  "homepage": "https://github.com/ArikaJs/arikajs/tree/main/packages/auth#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.24",
