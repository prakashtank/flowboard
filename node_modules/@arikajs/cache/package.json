{
  "name": "@arikajs/cache",
  "version": "0.10.2",
  "description": "Simple, fast, and driver-based caching system for the ArikaJS framework.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
